# VideoForge Configuration
# Copy this file to .env and fill in your values

# Google AI Studio API Key (get it free at https://aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# FFmpeg paths (leave as 'ffmpeg'/'ffprobe' if they are in system PATH)
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
